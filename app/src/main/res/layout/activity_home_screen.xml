<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".HomeScreen">
    <!-- for each button, bench will be a mockup, account + history needs backend implementation -->
    <!-- title -->
    <TextView
            android:id="@+id/infernoNaming"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Align"
            android:textSize="40sp"
            android:textStyle="bold"
            android:textColor="@color/align_dark_teal"
            android:letterSpacing="0.1"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="80dp" app:layout_constraintHorizontal_bias="0.496"/>
    <!-- squat -->
    <!-- bench -->
    <!-- history chart -->
    <ImageButton
            android:id="@+id/squat_button"
            android:layout_width="214dp"
            android:layout_height="192dp"
            android:src="@drawable/btn_homesquat"
            android:scaleType="centerCrop"
            android:background="@null"
            android:contentDescription="@string/categories"
            app:layout_constraintTop_toBottomOf="@id/infernoNaming"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="32dp" app:layout_constraintHorizontal_bias="0.473"
    />
    <ImageButton
            android:id="@+id/bench_button"
            android:layout_width="221dp"
            android:layout_height="185dp"
            android:src="@drawable/btn_homebench"
            android:scaleType="centerCrop"
            android:background="@null"
            android:contentDescription="@string/categories"
            app:layout_constraintTop_toBottomOf="@+id/squat_button"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.497"
            android:layout_marginTop="28dp"/>
    <ImageButton
            android:id="@+id/historybutton"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/btn_homehistory"
            android:background="@drawable/circle_button"
            android:scaleType="centerInside"
            android:padding="1dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"/>

    <!-- account management -->
    <ImageButton
            android:id="@+id/accountbutton"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/btn_homeaccount"
            android:background="@drawable/circle_button"
            android:scaleType="centerInside"
            android:padding="1dp"
            android:contentDescription="Account"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@id/historybutton"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="252dp"/>
    <ImageButton
            android:id="@+id/videoView"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/circle_button"
            android:scaleType="centerInside"
            android:padding="1dp"
            android:contentDescription="Account"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginBottom="1dp" app:layout_constraintEnd_toEndOf="parent"/>
    <androidx.constraintlayout.widget.Guideline android:layout_width="wrap_content" android:layout_height="wrap_content"
                                                android:id="@+id/guideline2" app:layout_constraintGuide_begin="20dp"
                                                android:orientation="horizontal"/>
</androidx.constraintlayout.widget.ConstraintLayout>